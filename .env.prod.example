POSTGRES_USER=cosmos
POSTGRES_PASSWORD=CHANGE_ME_TO_LONG_RANDOM_STRING
POSTGRES_DB=cosmos
POSTGRES_PORT=5432
DATABASE_URL=postgres://cosmos:CHANGE_ME_TO_LONG_RANDOM_STRING@db:5432/cosmos?sslmode=disable

APP_ENV=production
HTTP_ADDR=:8080
DB_MAX_CONNS=20
DB_MIN_CONNS=4
LOG_LEVEL=info
REQUEST_TIMEOUT=10s
READ_TIMEOUT=15s
WRITE_TIMEOUT=15s

CONNECT_RATE_RPS=20
CONNECT_RATE_BURST=40
WS_RATE_RPS=3
WS_RATE_BURST=5

CORS_ALLOWED_ORIGINS=https://cosmos.lavier.tech
CORS_ORIGINS=https://cosmos.lavier.tech

MIGRATE_ON_BOOT=false

NEXT_PUBLIC_SITE_URL=https://cosmos.lavier.tech
NEXT_PUBLIC_API_BASE_URL=https://cosmos.lavier.tech
NEXT_PUBLIC_API_ORIGIN=https://cosmos.lavier.tech
API_INTERNAL_URL=http://cosmos-api:8080

NEXT_PUBLIC_GOOGLE_VERIFICATION=
NEXT_PUBLIC_YANDEX_VERIFICATION=
NEXT_PUBLIC_YANDEX_METRIKA_ID=
NEXT_PUBLIC_GA4_ID=

NEXT_PUBLIC_UMAMI_SRC=https://metrics.lavier.tech/script.js
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
NEXT_PUBLIC_UMAMI_ALLOWED_HOSTS=metrics.lavier.tech

REVALIDATE_SECRET=CHANGE_ME_TO_LONG_RANDOM_STRING

COMPOSE_FILE=docker-compose.yml:docker-compose.prod.yml
IMAGE_PREFIX=
IMAGE_TAG=latest
