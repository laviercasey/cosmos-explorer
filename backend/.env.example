APP_ENV=development

HTTP_ADDR=:8080

DATABASE_URL=postgres://cosmos:cosmos@localhost:5432/cosmos?sslmode=disable

DB_MAX_CONNS=10
DB_MIN_CONNS=2

LOG_LEVEL=info

CORS_ALLOWED_ORIGINS=

MIGRATE_ON_BOOT=true

REQUEST_TIMEOUT=10s

READ_TIMEOUT=15s
WRITE_TIMEOUT=15s

CONNECT_RATE_RPS=20
CONNECT_RATE_BURST=40
WS_RATE_RPS=3
WS_RATE_BURST=5

SEED_SOURCE_DIR=../src/entities
